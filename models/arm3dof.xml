<mujoco model="arm3dof">

    <option gravity="0 0 0"/>

    <worldbody>

        <body name="link1" pos="0 0 0">

            <joint
                name="joint1"
                type="hinge"
                axis="0 0 1"/>

            <geom
                type="capsule"
                fromto="0 0 0 0.5 0 0"
                size="0.03"
                rgba="1 0 0 1"/>

            <body name="link2" pos="0.5 0 0">

                <joint
                    name="joint2"
                    type="hinge"
                    axis="0 0 1"/>

                <geom
                    type="capsule"
                    fromto="0 0 0 0.3 0 0"
                    size="0.03"
                    rgba="0 1 0 1"/>

                <body name="link3" pos="0.3 0 0">

                    <joint
                        name="joint3"
                        type="hinge"
                        axis="0 0 1"/>

                    <geom
                        type="capsule"
                        fromto="0 0 0 0.2 0 0"
                        size="0.03"
                        rgba="0 0 1 1"/>

                    <site
                        name="ee"
                        pos="0.2 0 0"
                        size="0.02"/>

                </body>

            </body>

        </body>

    </worldbody>

    <actuator>

        <motor
            joint="joint1"
            ctrlrange="-100 100"
            gear="1"/>

        <motor
            joint="joint2"
            ctrlrange="-100 100"
            gear="1"/>

        <motor
            joint="joint3"
            ctrlrange="-100 100"
            gear="1"/>

    </actuator>

</mujoco>